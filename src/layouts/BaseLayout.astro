---
import RouterMenu from '~/components/RouterMenu.vue'
import '~/styles/global.css'

interface Props {
  title?: string
  fullscreen?: boolean
}

const { title, fullscreen = false } = Astro.props
const fullTitle = title ? `${title} | 一般社団法人遠山郷応援会` : '一般社団法人遠山郷応援会'
const currentPath = Astro.url.pathname
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
  </head>
  <body>
    <main
      class:list={[
        'grow overflow-auto',
        !fullscreen && [
          'after:sticky',
          'after:bottom-0',
          'after:bg-gradient-to-t',
          'after:from-gray-100',
          'after:to-transparent',
          'after:opacity-90',
          'after:w-full',
          'after:h-20',
          'after:block',
          'before:top-0',
          'before:bg-gradient-to-b',
          'before:from-lime-400',
          'before:to-transparent',
          'before:w-full',
          'before:h-8',
          'before:opacity-25',
          'before:block',
        ],
      ]}
    >
      <slot />
    </main>
    <RouterMenu client:load currentPath={currentPath} />
    <footer
      class="text-sm py-1 border-t border-lime-300 bg-lime-100 text-gray-700 relative
             before:border-x-[0.58rem] before:border-b-[1rem] before:border-x-transparent before:border-b-green-500 before:absolute before:right-3.5 before:bottom-2
             after:border-x-[0.58rem] after:border-b-[1rem] after:border-x-transparent after:border-b-green-700 after:absolute after:right-2 after:bottom-1 after:scale-110 after:origin-bottom-right"
    >
      <a href="/" class="mx-auto w-fit block"> 一般社団法人遠山郷応援会 </a>
    </footer>
  </body>
</html>
