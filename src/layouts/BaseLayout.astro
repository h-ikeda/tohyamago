---
import RouterMenu from '~/components/RouterMenu.vue'
import '~/styles/global.css'

interface Props {
  title?: string
  fullscreen?: boolean
}

const { title, fullscreen = false } = Astro.props
const fullTitle = title ? `${title} | 一般社団法人遠山郷応援会` : '一般社団法人遠山郷応援会'
const currentPath = Astro.url.pathname
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <!-- タイポグラフィ: 見出し Noto Serif JP / 本文 Noto Sans JP (light 基調) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@300;400;500&family=Noto+Serif+JP:wght@300;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main
      class:list={[
        'grow overflow-auto',
        !fullscreen && [
          'after:sticky',
          'after:bottom-0',
          'after:bg-gradient-to-t',
          'after:from-base',
          'after:to-transparent',
          'after:opacity-90',
          'after:w-full',
          'after:h-20',
          'after:block',
          'before:top-0',
          'before:bg-gradient-to-b',
          'before:from-primary',
          'before:to-transparent',
          'before:w-full',
          'before:h-8',
          'before:opacity-10',
          'before:block',
        ],
      ]}
    >
      <slot />
    </main>
    <RouterMenu client:load currentPath={currentPath} />
    <footer
      class="text-sm py-2.5 border-t-4 border-sunlight bg-primary text-base relative
             before:border-x-[0.58rem] before:border-b-[1rem] before:border-x-transparent before:border-b-sunlight before:absolute before:right-3.5 before:bottom-3
             after:border-x-[0.58rem] after:border-b-[1rem] after:border-x-transparent after:border-b-accent after:absolute after:right-2 after:bottom-2 after:scale-110 after:origin-bottom-right"
    >
      <a href="/" class="mx-auto w-fit block hover:opacity-80 transition-opacity">
        一般社団法人遠山郷応援会
      </a>
    </footer>
  </body>
</html>
