---
import { getCollection } from 'astro:content'
import BaseLayout from '~/layouts/BaseLayout.astro'
import Container from '~/components/Container.astro'
import SectionHeading from '~/components/SectionHeading.astro'
import Button from '~/components/Button.astro'
import FarmCalendar from '~/components/FarmCalendar.tsx'

// 作物・地域イベントを Content Collections から取得し、表示順に整える。
const crops = (await getCollection('crops'))
  .map((entry) => ({ id: entry.id, ...entry.data }))
  .sort((a, b) => a.order - b.order)

const events = (await getCollection('events')).map((entry) => ({
  id: entry.id,
  ...entry.data,
}))
---

<BaseLayout title="農作業カレンダー">
  <Container size="wide" class="py-12 md:py-16">
    <SectionHeading as="h1" level="page" align="left" class="mb-6"
      >農作業カレンダー</SectionHeading
    >
    <p class="mb-8 max-w-2xl leading-loose text-body">
      下栗の里で一年を通して行う農作業の予定表です。どの作業も<span
        class="font-medium text-accent-strong">参加歓迎</span
      >。各バーには<span class="font-medium text-accent-strong"
        >作業強度の目安</span
      >（軽め / ふつう /
      しっかり）を表示しています。気になる作業のバーをタップすると、内容と参加方法をご覧いただけます。今月の列をハイライトしているので、「今・近いうちに参加できる作業」を探してみてください。
    </p>

    <FarmCalendar client:load crops={crops} events={events} />

    <div
      class="mt-10 flex flex-wrap items-center gap-3 rounded-3xl border border-primary/10 bg-surface px-6 py-6 shadow-sm"
    >
      <p class="grow leading-loose text-body">
        日程の詳細や最新の募集状況は、はじめての方向けの案内とボランティア募集ページでご確認いただけます。
      </p>
      <Button href="/join" variant="outline">はじめての方へ</Button>
      <Button href="https://activo.jp/s/a/119414">ボランティア募集を見る</Button
      >
    </div>
  </Container>
</BaseLayout>
