---
import { Image } from 'astro:assets'
import BaseLayout from '~/layouts/BaseLayout.astro'
import HomeTabs from '~/components/HomeTabs.vue'
import Posts from '~/components/Posts.astro'
import farmImage from '~/assets/farm.jpg'
---

<BaseLayout>
  <section class="px-4 pt-12 pb-8 text-center sm:pt-16">
    <p
      class="font-serif text-base/relaxed text-accent tracking-wide mb-3 md:text-lg
             before:content-['▲'] before:mr-2 before:text-xs before:align-middle before:text-accent-soft"
    >
      秘境の息遣いと、守る人の想いを伝える
    </p>
    <h1 class="font-serif font-medium text-primary text-2xl md:text-4xl">
      一般社団法人遠山郷応援会
    </h1>
  </section>
  <section class="mx-auto mb-10 w-full max-w-4xl px-4 sm:px-6">
    <Image
      src={farmImage}
      alt="遠山郷の農地と山並み"
      class="aspect-video w-full rounded-2xl object-cover shadow-md"
    />
  </section>
  <HomeTabs client:load>
    <Posts slot="feed" />
  </HomeTabs>
</BaseLayout>
