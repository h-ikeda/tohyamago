---
import { getCollection } from 'astro:content'
import BaseLayout from '~/layouts/BaseLayout.astro'
import BlurImage from '~/components/BlurImage.astro'
import Container from '~/components/Container.astro'
import SectionHeading from '~/components/SectionHeading.astro'
import Button from '~/components/Button.astro'
import Card from '~/components/Card.astro'
import JourneyCards from '~/components/JourneyCards.astro'
import Posts from '~/components/Posts.astro'
import { upcomingTasks } from '~/components/homeTasks'
import type { Intensity } from '~/components/FarmCalendar'
import heroImage from '~/assets/hero-photo.jpg'
import mountsImage from '~/assets/mounts.jpg'

// 「今月の活動」: 農作業カレンダー (crops) から当月 (無ければ最も近い先の月) に
// 参加できる作業を抽出する。ビルド時の月を起点にするため、季節に追従して自動更新される。
const crops = (await getCollection('crops')).map((entry) => ({
  id: entry.id,
  ...entry.data,
}))
const currentMonth = new Date().getMonth() + 1
const preview = upcomingTasks(crops, currentMonth)
const isThisMonth = preview.month === currentMonth
// 表示は数件にとどめ、全体はカレンダーへ誘導する
const previewTasks = preview.tasks.slice(0, 6)
const moreCount = preview.tasks.length - previewTasks.length

const intensityLabel: Record<Intensity, string> = {
  light: '軽め',
  medium: 'ふつう',
  hard: 'しっかり',
}
---

<BaseLayout>
  <!-- ヒーロー: レスポンシブに切り替える。
       - スマホ (~md): 写真を「切れない」バナー (元画像と同じ 4:3 をそのまま表示) として
         上に置き、テキストは下のクリーム地に重ねず配置する。狭く背の低い端末でも
         写真が中途半端に切れて見えず、文字は地色の上で確実に読める。
       - md 以上: 写真を全面背景にし、テキストをダークグリーンのスクリム上に白文字で重ねる。 -->
  <section class="relative isolate overflow-hidden">
    <!-- メディア: スマホは通常フローのバナー、md 以上は絶対配置でセクション全面を覆う -->
    <div
      class="relative aspect-[4/3] w-full overflow-hidden md:absolute md:inset-0 md:-z-10 md:aspect-auto md:h-full"
    >
      <BlurImage
        src={heroImage}
        alt="遠山郷の急斜面に広がる畑と山並み"
        loading="eager"
        fetchpriority="high"
        fade={false}
        sizes="100vw"
        class="absolute inset-0 h-full w-full"
        imgClass="h-full w-full object-cover object-center"
      />
      <!-- スクリム: md 以上でのみ全面に重ね、下部の白文字の可読性 (WCAG AA) を確保する。
           スマホでは写真をそのまま見せる (テキストは下のクリーム地に置くため不要)。 -->
      <div
        aria-hidden="true"
        class="absolute inset-0 md:bg-gradient-to-t md:from-primary-deep/92 md:via-primary-deep/42 md:to-transparent"
      >
      </div>
    </div>
    <Container
      size="wide"
      class="flex flex-col items-center gap-5 px-4 py-8 text-center md:min-h-[clamp(24rem,68svh,38rem)] md:justify-end md:pb-12 md:pt-24"
    >
      <span
        class="flex w-fit items-center gap-2 rounded-full bg-primary-deep px-4 py-1 font-serif text-sm tracking-wide text-white ring-1 ring-white/25 [text-shadow:0_1px_3px_rgba(15,46,33,0.6)]"
      >
        一般社団法人遠山郷応援会
      </span>
      <h1
        class="font-serif text-3xl font-medium leading-snug text-primary md:text-5xl md:text-white md:[text-shadow:0_2px_8px_rgba(15,46,33,0.55)]"
      >
        <span class="inline-block">秘境の里を、</span><span class="inline-block"
          >楽しく未来へ</span
        >
      </h1>
      <p
        class="mx-auto max-w-xl text-justify leading-loose text-body md:text-white md:[text-shadow:0_1px_4px_rgba(15,46,33,0.75)]"
      >
        長野県の南端、南アルプスの麓に抱かれた秘境・遠山郷。谷あいの里に受け継がれてきた景観と暮らしを、地域の人とボランティアが力を合わせて、楽しみながら次の世代へつないでいきます。
      </p>
      <div class="mt-2 flex flex-wrap justify-center gap-3">
        <Button href="/join">活動に参加する</Button>
        <Button href="/calendar" variant="outline">秘境の一年を見る</Button>
      </div>
    </Container>
  </section>

  <Container size="wide" class="py-12 md:py-16">
    <!-- 3 導線カード (参加 / 成果品 / 支える) -->
    <section class="mb-16">
      <SectionHeading as="h2" class="mb-8"
        >参加も、応援も、お待ちしています</SectionHeading
      >
      <JourneyCards />
    </section>

    <!-- 今月の活動 (農作業カレンダーへの誘導) -->
    <section class="mb-16">
      <div
        class="rounded-3xl border border-primary/10 bg-gradient-to-br from-surface to-sunlight-soft/30 px-6 py-8 shadow-sm md:px-10"
      >
        <SectionHeading as="h2" align="left" class="mb-2">
          {isThisMonth ? `今月の活動` : `まもなく始まる活動`}
        </SectionHeading>
        <p class="mb-6 text-sm leading-relaxed text-body/80">
          {
            isThisMonth
              ? `${preview.month}月に参加できる作業です。`
              : `${preview.month}月から参加できる作業です。`
          }気になる作業があれば、ぜひお気軽にご参加ください。
        </p>
        {
          previewTasks.length > 0 ? (
            <ul class="grid gap-3 sm:grid-cols-2">
              {previewTasks.map((task) => (
                <li class="flex gap-3 rounded-2xl border border-primary/10 bg-surface px-4 py-3">
                  <span
                    aria-hidden="true"
                    class="mt-1 h-3 w-3 shrink-0 rounded-full"
                    style={`background-color:${task.color}`}
                  />
                  <div class="min-w-0">
                    <div class="flex flex-wrap items-center gap-x-2 gap-y-1">
                      <span class="font-medium text-primary">
                        {task.emoji} {task.cropName}
                      </span>
                      <span class="text-body">{task.label}</span>
                      <span class="rounded-full bg-primary/5 px-2 py-0.5 text-xs text-body/70">
                        {intensityLabel[task.intensity]}
                      </span>
                    </div>
                    {task.note && (
                      <p class="mt-1 text-sm leading-relaxed text-body/80">
                        {task.note}
                      </p>
                    )}
                  </div>
                </li>
              ))}
            </ul>
          ) : (
            <p class="leading-loose text-body">
              年間の農作業の予定は、農作業カレンダーでご覧いただけます。
            </p>
          )
        }
        {
          moreCount > 0 && (
            <p class="mt-3 text-sm text-body/70">
              ほか {moreCount} 件の作業もカレンダーに掲載しています。
            </p>
          )
        }
        <div class="mt-6 flex flex-wrap gap-3">
          <Button href="/calendar">農作業カレンダー</Button>
          <Button href="/join" variant="outline">はじめての方へ</Button>
        </div>
      </div>
    </section>

    <!-- 始まり物語 teaser -->
    <section class="mb-16">
      <Card class="overflow-hidden md:grid md:grid-cols-2">
        <BlurImage
          src={mountsImage}
          alt="遠山郷の山並みと谷あいの里"
          sizes="(min-width: 768px) 50vw, 100vw"
          class="aspect-video h-full w-full md:aspect-auto"
          imgClass="h-full w-full object-cover"
        />
        <div class="flex flex-col justify-center gap-3 px-6 py-8 md:px-10">
          <SectionHeading as="h2" level="sub" align="left">
            一枚の貼り紙から
          </SectionHeading>
          <p class="leading-loose text-body">
            「二度芋を、つくってみませんか」——たった一枚の貼り紙から始まった、ある秘境通いの物語。私たちがどうやって遠山郷とつながり、活動を続けてきたのかを、読み物としてお届けします。
          </p>
          <div class="mt-2">
            <Button href="/story" variant="outline">始まりの物語を読む</Button>
          </div>
        </div>
      </Card>
    </section>

    <!-- 近況ダイジェスト: 最新数件のみを載せ、続きは近況アーカイブ /news へ誘導する。
         id="feed" は旧 /#feed ブックマーク互換のためのアンカー。 -->
    <section id="feed" class="scroll-mt-24">
      <SectionHeading as="h2" class="mb-2">近況</SectionHeading>
      <p class="mb-8 text-center text-sm leading-relaxed text-body/80">
        活動の様子を随時お届けしています。
      </p>
      <Posts limit={3} />
      <div class="mt-8 flex justify-center">
        <Button href="/news" variant="outline"
          >これまでの活動をもっと見る</Button
        >
      </div>
    </section>
  </Container>
</BaseLayout>
