---
import { getCollection, render } from 'astro:content'
import BlurImage from '~/components/BlurImage.astro'
import BaseLayout from '~/layouts/BaseLayout.astro'
import Container from '~/components/Container.astro'
import Button from '~/components/Button.astro'
import NewsCta from '~/components/NewsCta.astro'
import ArrowIcon from '~/components/ArrowIcon.astro'
import { formatPostDate } from '~/components/postDate'
import { postExcerpt } from '~/components/postExcerpt'
import {
  SITE_NAME,
  absoluteUrl,
  normalizeDescription,
  articleJsonLd,
  breadcrumbJsonLd,
} from '~/components/siteMeta'

// 記事個別ページ (共有・SEO 用)。全記事を新しい順に並べ、
// 前後の記事への導線 (新しい記事 / 古い記事) も静的に用意する。
export async function getStaticPaths() {
  const posts = (await getCollection('posts')).sort(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
  )
  return posts.map((post, index) => ({
    params: { slug: post.id },
    props: {
      post,
      newer: posts[index - 1], // 1 つ新しい記事 (先頭なら undefined)
      older: posts[index + 1], // 1 つ古い記事 (末尾なら undefined)
    },
  }))
}

const { post, newer, older } = Astro.props
const { Content } = await render(post)

// SEO/SNS 用メタ: 本文抜粋を説明文に、先頭画像を OG 画像にする。
// 構造化データは記事 (BlogPosting) とパンくず (BreadcrumbList) を付与する。
const excerpt = normalizeDescription(
  postExcerpt(post.body, 120) || `${post.data.title}｜遠山郷応援会の近況`,
)
const pageUrl = absoluteUrl(`/news/${post.id}`)
const ogImage = post.data.images[0]
const structuredData = [
  articleJsonLd({
    title: post.data.title,
    description: excerpt,
    url: pageUrl,
    image: ogImage ? absoluteUrl(ogImage.src) : undefined,
    datePublished: post.data.date.toISOString(),
    tags: post.data.tags,
  }),
  breadcrumbJsonLd([
    { name: SITE_NAME, url: absoluteUrl('/') },
    { name: '近況', url: absoluteUrl('/news') },
    { name: post.data.title, url: pageUrl },
  ]),
]
---

<BaseLayout
  title={`${post.data.title}｜近況`}
  description={excerpt}
  image={ogImage}
  imageAlt={post.data.title}
  ogType="article"
  publishedTime={post.data.date}
  tags={post.data.tags}
  jsonLd={structuredData}
>
  <Container class="py-10 md:py-14">
    <nav class="mb-6 text-sm">
      <a
        href="/news"
        class="inline-flex items-center gap-1 text-accent-strong before:content-['←'] hover:underline"
      >
        近況一覧へ戻る
      </a>
    </nav>

    <article>
      <time
        class="block font-mono text-sm font-medium text-accent-strong"
        datetime={post.data.date.toISOString()}
      >
        {formatPostDate(post.data.date)}
      </time>

      <h1
        class="mt-2 font-serif text-2xl leading-snug font-medium text-primary md:text-3xl"
      >
        {post.data.title}
      </h1>

      <div class="post-body mt-5 text-justify text-lg leading-loose text-body">
        <Content />
      </div>

      {
        post.data.images.length > 0 && (
          <div class="mt-8 grid gap-4">
            {post.data.images.map((img) => (
              <BlurImage
                src={img}
                alt=""
                sizes="(min-width: 768px) 720px, 100vw"
                class="w-full overflow-hidden rounded-2xl border border-primary/10"
                imgClass="w-full object-cover saturate-[0.9]"
              />
            ))}
          </div>
        )
      }

      {
        post.data.sourceUrl && (
          <p class="mt-6 text-sm text-body/70">
            <a
              href={post.data.sourceUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="text-accent-strong hover:underline"
            >
              元の投稿を見る
            </a>
          </p>
        )
      }

      {
        post.data.tags.length > 0 && (
          <ul class="mt-8 flex flex-wrap gap-2" aria-label="タグ">
            {post.data.tags.map((tag) => (
              <li class="rounded-full bg-primary/5 px-3 py-1 text-sm text-accent-strong">
                #{tag}
              </li>
            ))}
          </ul>
        )
      }
    </article>

    <!-- 前後の記事への導線 (新しい / 古い) -->
    <nav
      class="mt-12 grid gap-3 border-t border-primary/10 pt-8 sm:grid-cols-2"
      aria-label="前後の記事"
    >
      {
        newer ? (
          <a
            href={`/news/${newer.id}`}
            class="group rounded-2xl border border-primary/10 bg-surface px-5 py-4 transition-shadow hover:shadow-md"
          >
            <span class="flex items-center gap-1 text-xs text-body/60">
              <ArrowIcon class="h-[1.1em] w-[1.1em] -scale-x-100 transition-transform motion-safe:group-hover:-translate-x-0.5" />
              新しい記事
            </span>
            <span class="mt-1 block leading-relaxed text-primary">
              {newer.data.title}
            </span>
          </a>
        ) : (
          <span class="hidden sm:block" />
        )
      }
      {
        older && (
          <a
            href={`/news/${older.id}`}
            class="group rounded-2xl border border-primary/10 bg-surface px-5 py-4 text-right transition-shadow hover:shadow-md"
          >
            <span class="flex items-center justify-end gap-1 text-xs text-body/60">
              古い記事
              <ArrowIcon class="h-[1.1em] w-[1.1em] transition-transform motion-safe:group-hover:translate-x-0.5" />
            </span>
            <span class="mt-1 block leading-relaxed text-primary">
              {older.data.title}
            </span>
          </a>
        )
      }
    </nav>

    <div class="mt-10 flex flex-wrap justify-center gap-3">
      <Button href="/news" variant="outline">近況一覧</Button>
      <Button href="/news/archive" variant="outline">年・季節でたどる</Button>
    </div>

    <NewsCta class="mt-12" />
  </Container>
</BaseLayout>

<style>
  .post-body :global(p + p) {
    margin-top: 1em;
  }
</style>
