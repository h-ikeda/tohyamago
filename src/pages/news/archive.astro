---
import { getCollection } from 'astro:content'
import BaseLayout from '~/layouts/BaseLayout.astro'
import Container from '~/components/Container.astro'
import SectionHeading from '~/components/SectionHeading.astro'
import Button from '~/components/Button.astro'
import NewsCta from '~/components/NewsCta.astro'
import { groupPostsByYear } from '~/components/postArchive'
import { formatPostDate } from '~/components/postDate'
import { getSeason, seasonLabel, SEASONS } from '~/components/postSeason'

// 近況の年別アーカイブ (これまでの歩みを年表的にたどる索引)。
// 記事スキーマにタグ・カテゴリが無いため、後方互換を保てる「公開年」で章立てし、
// 季節は日付から判定できるので、年をまたいだ季節フィルタを重ねる。
const sorted = (await getCollection('posts')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
)
const groups = groupPostsByYear(sorted)
const total = sorted.length

// 季節フィルタの選択肢: すべて + 春夏秋冬
const seasonFilters = [
  { id: 'all', label: 'すべて' },
  ...SEASONS.map((s) => ({ id: s.id, label: s.label })),
]
---

<BaseLayout title="近況アーカイブ">
  <section
    class="bg-gradient-to-b from-sky-soft via-base to-base px-4 pt-12 pb-8 text-center sm:pt-16"
  >
    <span
      class="mx-auto mb-4 flex w-fit items-center gap-2 rounded-full bg-sunlight-soft px-4 py-1 font-serif text-sm tracking-wide text-primary-deep
             before:text-xs before:text-accent-strong before:content-['▲']"
    >
      近況アーカイブ
    </span>
    <h1
      class="font-serif text-3xl font-medium leading-snug text-primary md:text-4xl"
    >
      年と季節でたどる、これまでの歩み
    </h1>
    <p class="mx-auto mt-5 max-w-2xl leading-loose text-body">
      {total} 件の記録を、年ごとにまとめました。季節で絞り込めば、年をまたいで「その季節の活動」をたどれます。
    </p>
    <div class="mt-6 flex justify-center">
      <Button href="/news" variant="outline">最新の近況を見る</Button>
    </div>
  </section>

  <Container class="py-12 md:py-16">
    <div data-archive>
      <!-- 季節フィルタ (日付から判定。JS 無効時は全件表示のまま) -->
      <div class="mb-8">
        <p class="mb-3 text-center text-sm text-body/70">季節でしぼり込む</p>
        <div
          class="flex flex-wrap justify-center gap-2"
          role="group"
          aria-label="季節でしぼり込む"
        >
          {
            seasonFilters.map((f) => (
              <button
                type="button"
                data-season-filter={f.id}
                aria-pressed={f.id === 'all' ? 'true' : 'false'}
                class="rounded-full border border-primary/15 bg-surface px-4 py-1.5 text-sm text-primary transition-colors hover:border-accent-strong hover:text-accent-strong aria-pressed:border-accent-strong aria-pressed:bg-accent-strong aria-pressed:text-white"
              >
                {f.label}
              </button>
            ))
          }
        </div>
      </div>

      <!-- 年へのジャンプナビ -->
      <nav class="mb-12" aria-label="年で絞り込む">
        <ul class="flex flex-wrap justify-center gap-2">
          {
            groups.map((group) => (
              <li data-year-nav={group.year}>
                <a
                  href={`#y${group.year}`}
                  class="inline-flex items-center gap-1 rounded-full border border-primary/15 bg-surface px-4 py-1.5 text-sm text-primary transition-colors hover:border-accent-strong hover:text-accent-strong"
                >
                  {group.year}
                  <span class="text-xs text-body/60">
                    ({group.posts.length})
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="space-y-14">
        {
          groups.map((group) => (
            <section
              id={`y${group.year}`}
              data-year-section
              data-year={group.year}
              class="scroll-mt-24"
            >
              <SectionHeading as="h2" align="left" class="mb-5">
                {group.year}年
                <span class="ml-2 align-middle text-base font-normal text-body/60">
                  <span data-count>{group.posts.length}</span> 件
                </span>
              </SectionHeading>
              <ul class="divide-y divide-primary/10 overflow-hidden rounded-2xl border border-primary/10 bg-surface">
                {group.posts.map((post) => {
                  const season = getSeason(post.data.date)
                  return (
                    <li data-season={season}>
                      <a
                        href={`/news/${post.id}`}
                        class="flex flex-col gap-1 px-5 py-4 transition-colors hover:bg-sunlight-soft/30 focus:outline-none focus-visible:bg-sunlight-soft/40 sm:flex-row sm:items-baseline sm:gap-4"
                      >
                        <time
                          class="shrink-0 font-mono text-xs font-medium text-accent-strong sm:w-36"
                          datetime={post.data.date.toISOString()}
                        >
                          {formatPostDate(post.data.date)}
                        </time>
                        <span class="min-w-0 flex-1 truncate leading-relaxed text-body">
                          {post.data.title}
                        </span>
                        <span class="shrink-0 self-start rounded-full bg-primary/5 px-2 py-0.5 text-xs text-body/60 sm:self-auto">
                          {seasonLabel(season)}
                        </span>
                      </a>
                    </li>
                  )
                })}
              </ul>
            </section>
          ))
        }
      </div>
    </div>

    <NewsCta class="mt-16" />
  </Container>
</BaseLayout>

<script>
  import { applySeasonFilter } from '~/components/newsArchiveFilter'

  const root = document.querySelector<HTMLElement>('[data-archive]')
  if (root) {
    root
      .querySelectorAll<HTMLElement>('[data-season-filter]')
      .forEach((btn) => {
        btn.addEventListener('click', () => {
          applySeasonFilter(root, btn.dataset.seasonFilter ?? 'all')
        })
      })
  }
</script>
