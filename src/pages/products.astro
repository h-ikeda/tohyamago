---
import { getCollection } from 'astro:content'
import { Image } from 'astro:assets'
import BaseLayout from '~/layouts/BaseLayout.astro'
import Container from '~/components/Container.astro'
import SectionHeading from '~/components/SectionHeading.astro'
import Card from '~/components/Card.astro'
import Button from '~/components/Button.astro'
import ProductCard from '~/components/ProductCard.astro'
import farmImage from '~/assets/farm.jpg'

const SHOP_URL = 'https://shop.tohyamago.org'

// 成果品の物語。emoji / color / name は作物コレクション (crops) を単一情報源として
// 紐づけ、ここではショーケース用の文章・成果品・旬だけを管理する。
const showcase = [
  {
    id: 'shimoguri-imo',
    tagline: '日本のチロル・下栗の急斜面で育つ、小さな在来芋',
    story: [
      '標高 1,000m 前後の急傾斜地に石垣を積んで拓かれた、下栗の里の畑。ここで代々受け継がれてきたのが、ひと夏に二度植え付けられることから「二度芋」とも呼ばれる小ぶりな在来のじゃがいもです。',
      '種芋の植え付けから土寄せ・草取り、盛夏の芋掘りまでを、応援団の手で一つひとつ。掘りたてのほくほくとした味わいは、この時期この場所ならではの楽しみです。',
    ],
    makes: [
      { label: '下栗芋（生芋）', note: '夏に収穫した掘りたてを数量限定で' },
      { label: 'いも田楽', note: '串に刺して味噌だれで、下栗の郷土の味' },
    ],
    season: '植え付け 3〜4 月／収穫は盛夏（7〜8 月）',
  },
  {
    id: 'shimoguri-soba',
    tagline: '芋を掘った同じ畑から、白い花を経て実る新蕎麦',
    story: [
      '下栗芋を収穫したあとの畑に、そのまま蕎麦の種を蒔きます。夏の終わりには一面に白い花が咲き揃い、秋には黒く実った蕎麦を皆で刈り取ります。',
      '刈り取った蕎麦は天日で乾かし、脱穀して玄蕎麦に。冬には挽きたて・打ちたての新蕎麦を味わう会も開いています。',
    ],
    makes: [
      { label: '玄蕎麦・そば粉', note: '秋に収穫・脱穀した下栗産の蕎麦' },
      { label: '新蕎麦', note: '晩秋〜冬、収穫したての香りを楽しむ' },
    ],
    season: '種蒔き 7 月／収穫・脱穀は晩秋（10〜11 月）',
  },
  {
    id: 'zairai-daizu',
    tagline: 'はざかけで天日に干す、この土地の在来大豆',
    story: [
      '蕎麦畑と並んで育てているのが、遠山郷に受け継がれてきた在来の大豆です。鳥よけのネットを張って種を蒔き、夏の草刈りで見守りながら、晩秋の収穫を迎えます。',
      '刈り取った株は「はざかけ」にして天日でじっくり乾燥。その年の〆の作業として脱穀し、ふっくらとした大豆に仕上げます。',
    ],
    makes: [
      { label: '在来大豆', note: '天日干しでうまみを蓄えた乾燥大豆' },
      {
        label: '味噌・きな粉 など',
        note: '大豆を活かした加工品づくりにも挑戦',
      },
    ],
    season: '種蒔き 5 月／収穫・脱穀は晩秋（11〜12 月）',
  },
  {
    id: 'ocha',
    tagline: '「一芯三葉」で手摘みする、数量限定の新茶',
    story: [
      '春一番の整枝・施肥から始まり、初夏には新芽を手摘みします。「一芯三葉」——芯と若い葉だけを摘む昔ながらのやり方を、地域の人に教わりながら受け継いでいます。',
      'ある年は手摘みした 15kg の生葉が、茶工場での加工を経て 3kg ほどの茶葉に。手間をかけたぶんだけ、香り高い一杯になります。仕上がったお茶は数量限定でお分けしています。',
    ],
    makes: [
      { label: '新茶（仕上げ茶）', note: '手摘み・加工した数量限定の煎茶' },
    ],
    season: '整枝 3 月／茶摘み（新茶）は初夏（5 月）',
  },
]

// 作物コレクションと突き合わせ、ブランド情報 (emoji / color / name) を補う。
// 表示順は crops の order に従う。
const cropById = new Map(
  (await getCollection('crops')).map((c) => [c.id, c.data]),
)

const products = showcase
  .map((item) => {
    const crop = cropById.get(item.id)
    if (!crop) return null
    return {
      ...item,
      name: crop.name,
      emoji: crop.emoji,
      color: crop.color,
      order: crop.order,
    }
  })
  .filter((p): p is NonNullable<typeof p> => p !== null)
  .sort((a, b) => a.order - b.order)
---

<BaseLayout title="成果品紹介">
  <!-- ヒーロー: 「こんなものが作れています」を最初に印象づける -->
  <section
    class="relative overflow-hidden bg-gradient-to-b from-sunlight-soft/50 via-base to-base px-4 pt-12 pb-10 text-center sm:pt-16"
  >
    <span
      class="mx-auto mb-4 flex w-fit items-center gap-2 rounded-full bg-sunlight-soft px-4 py-1 font-serif text-sm tracking-wide text-primary-deep
             before:text-xs before:text-accent-strong before:content-['▲']"
    >
      成果品紹介
    </span>
    <h1
      class="font-serif text-3xl font-medium leading-snug text-primary md:text-4xl"
    >
      遠山郷の畑から、できました
    </h1>
    <p
      class="mx-auto mt-5 max-w-2xl text-left leading-loose text-body sm:text-center"
    >
      急斜面の小さな畑で、種まきから収穫・加工まで応援団の手で。下栗芋・蕎麦・大豆・お茶——遠山郷の畑で育て、かたちにしてきた成果品をご紹介します。気に入ったものは、オンラインショップでお求めいただけます。
    </p>
    <div class="mx-auto mt-8 w-full max-w-3xl">
      <Image
        src={farmImage}
        alt="遠山郷の急斜面に広がる畑と山並み"
        loading="eager"
        fetchpriority="high"
        class="aspect-video w-full rounded-3xl object-cover shadow-lg ring-1 ring-primary/10"
      />
    </div>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <Button href={SHOP_URL}>オンラインショップを見る</Button>
      <Button href="/calendar" variant="outline">畑の一年を見る</Button>
    </div>
  </section>

  <Container size="wide" class="py-12 md:py-16">
    <!-- 少量・手仕事であることの価値づけ -->
    <section class="mb-14">
      <Card
        class="border-t-4 border-t-sunlight px-6 py-8 leading-loose text-body md:px-10"
      >
        <p class="indent-4">
          遠山郷の畑の多くは、機械の入りにくい急傾斜地にあります。だからこそ、種まきや草取り、収穫の一つひとつに人の手がかかります。私たちはそこに集う人たちと一緒に、無理のない範囲で作物を育て、採れたものを丁寧にかたちにしてきました。
        </p>
        <p class="mt-4 indent-4">
          どれも大量生産はできませんが、旬ごとに「この土地らしい味」を少しずつお届けしています。買って応援していただくことが、畑を守り、活動を続ける力になります。
        </p>
      </Card>
    </section>

    <!-- 成果品ショーケース -->
    <section class="mb-16">
      <SectionHeading as="h2" align="left" class="mb-6"
        >育てているもの・つくれるもの</SectionHeading
      >
      <div class="grid gap-6 md:grid-cols-2">
        {
          products.map((p) => (
            <ProductCard
              name={p.name}
              emoji={p.emoji}
              color={p.color}
              tagline={p.tagline}
              story={p.story}
              makes={p.makes}
              season={p.season}
            />
          ))
        }
      </div>
      <p class="mt-6 text-sm leading-relaxed text-body/80">
        ※
        成果品はいずれも少量生産・季節限定です。販売の有無や在庫はオンラインショップでご確認ください。新しい作物や加工品にも少しずつ挑戦しています。
      </p>
    </section>

    <!-- つくる側にまわる導線 (コミュニティ拡大を最優先する方針) -->
    <section class="mb-16">
      <Card class="border-l-4 border-l-primary-soft px-6 py-8 md:px-10">
        <SectionHeading as="h2" level="sub" align="left" class="mb-4"
          >「食べる」から「つくる」へ</SectionHeading
        >
        <p class="leading-loose text-body">
          これらの成果品は、特別な誰かではなく、畑に集まったいろいろな人の手で生まれています。植え付けや収穫、お茶摘みは、初めての方も大歓迎。気になる作業があれば、ぜひ一度畑へ来てみませんか。あなたの手も、来年の成果品の一部になります。
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <Button href="/join">はじめての方へ</Button>
          <Button href="/calendar" variant="outline">農作業カレンダー</Button>
        </div>
      </Card>
    </section>

    <!-- ショップへの送客 CTA -->
    <section
      class="rounded-3xl border border-primary/10 bg-gradient-to-br from-sunlight-soft/60 to-surface px-6 py-10 text-center md:px-12"
    >
      <SectionHeading as="h2" align="center" class="mb-4"
        >遠山郷の味を、おうちで</SectionHeading
      >
      <p class="mx-auto max-w-xl leading-loose text-body">
        その時々の旬の成果品を、オンラインショップでお求めいただけます。お買い求めいただくことが、遠山郷の畑と暮らしを守る応援になります。
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <Button href={SHOP_URL}>オンラインショップへ</Button>
        <Button href="/support" variant="outline">活動を寄付で支える</Button>
      </div>
    </section>
  </Container>
</BaseLayout>
