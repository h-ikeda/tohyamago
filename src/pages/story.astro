---
import { Image } from 'astro:assets'
import BaseLayout from '~/layouts/BaseLayout.astro'
import Container from '~/components/Container.astro'
import StoryReader, { type StoryPage } from '~/components/StoryReader.tsx'
import mountsImage from '~/assets/mounts.jpg'

/*
 * 「活動の始まり物語」。
 * 運営から提供された実話の下書きを、初見の来訪者でも情景が浮かぶよう
 * ライトノベル風に編集・脚色した読み物。StoryReader (React 島) が章ごとの
 * ページ送りを担う。各ページ末尾には実話ベース + AI 編集である旨を明示する。
 *
 * 理解の階段「purpose(理念) → story(経緯) → join(参加)」の中段を担うため、
 * 末尾の CTA は /join・近況へ送り出す。
 */
const pages: StoryPage[] = [
  {
    kicker: 'プロローグ',
    title: '冬の、秘境へ',
    paragraphs: [
      'ある年の冬。私は何人かの友人とともに、南信州の秘境へ向かっていた。',
      '長野県の南の端、赤石山脈――南アルプスの西の麓に、遠山郷と呼ばれる谷あいの里がある。新幹線も高速道路の出口も遠く、くねくねと山道を登った先にようやくたどり着く、文字どおりの「秘境」だ。',
      'そもそもの言い出しっぺは、各地の山間地域にやたらと詳しい友人だった。「面白いところがあるから」と、ただそれだけの理由で、私たちは冬の谷へ遊びに行くことにしたのだった。',
      '',
      '正直なところ、もう記憶は薄い。それでも、数少ない観光スポットをひとしきり見て回ったことは覚えている。「ビュースポットがある」と聞いて勇んで向かえば、その入り口はほとんど獣道のようなものだったし、夜は囲炉裏を囲んで、目に染みるほど煙い思いをした。',
      'けれど、その不便さこそがよかった。煙たさも、心細さも、ぜんぶひっくるめて――ここには確かに、ほかでは味わえない秘境感があった。',
      'このとき私は、まだ知らない。この谷に、これから何年も通うことになるなんて。',
    ],
  },
  {
    kicker: '第一話',
    title: '一枚の貼り紙',
    paragraphs: [
      '遠山郷の中心、上村の上町に、「祭り伝承館」という小さな施設がある。',
      'この地に古くから伝わる霜月祭り――湯立神楽の湯気の向こうに神々の面が浮かぶ、国指定重要無形民俗文化財の祭り――その映像や、実際に使われる面の数々が展示されている。外には昔の暮らしぶりがしのばれる古い民家も公開されていて、囲炉裏の匂いがそのまま染みついていそうな場所だった。',
      '',
      'その伝承館の片隅に、一枚の貼り紙がしてあった。',
      '正確な文言はもう覚えていない。けれど、こんなことが書かれていた。',
      '',
      '「二度芋を、つくってみませんか」',
      '',
      'なんでも、下栗の里という集落の景観を守るための事業らしかった。標高千メートルを超える急斜面に畑が段々と連なる、「天空の里」とも呼ばれる場所だ。耕す人の減った遊休農地を、ボランティアの手でもう一度よみがえらせる――そういう取り組みだという。',
      '二度芋って、何だろう。じゃがいも、だろうか。',
      '私の頭の中には、ひとつの素朴な疑問だけが、ぽつんと浮かんでいた。',
    ],
  },
  {
    kicker: '第二話',
    title: '二度芋は、二度芋だ',
    paragraphs: [
      '気になった私は、施設の管理人さんらしき人をつかまえて、思いきって尋ねてみた。',
      'その人いわく、二度芋というのは小さな芋で、白いのと、赤っぽいのとがあるという。そして、一年に二度も収穫できるから「二度芋」なのだ、と。なるほど、二期作ができるということか。',
      '',
      '「じゃあ、じゃがいもの仲間かな?」',
      '何の気なしに、私はそう口にした。',
      '',
      '「二度芋は、二度芋だ。」',
      '',
      '……え。',
      'ちがう、の?',
      '',
      '返ってきたのは、ただそれだけの、けれど妙に揺るがない一言だった。後で知ったことだが、これは下栗芋とも呼ばれる、この土地に根づいた伝統野菜なのだという。種芋を絶やさず受け継いできた、谷の暮らしそのもののような作物だった。',
      '新興住宅街で育った私には、農作業の経験なんてまるでなかった。土に触れたことすら、ほとんどない。それでも――いや、だからこそ、ふしぎと興味だけは湧いてきた。',
      'よく分からんけど、つくってみるか。',
      'そんな軽い気持ちで、私は下栗芋づくりに参加することになったのだった。',
    ],
  },
  {
    kicker: '第三話',
    title: 'はじめての農作業',
    paragraphs: [
      '翌春。私は約束どおり、下栗の里に立っていた。',
      'とくに初めての年は、作付けから収穫まで、地域の方々がそれはもう丁寧に、手取り足取り教えてくれた。種芋の置き方、土の寄せ方、草の取り方。ひとつひとつに、長い年月で磨かれた理屈があった。',
      '',
      'おどろいたのは、その「先生」たちの年齢だ。六十代で定年退職したくらいの人が、ここでは「若手」と呼ばれる。高齢化はとっくに進んでいる。けれど、畑に立つ人たちはみな、本当に若者みたいに元気だった。坂道をひょいひょい登り、冗談を飛ばし、よく笑う。こちらが息を切らしているのが、なんだか申し訳ないくらいだった。',
      '',
      'この耕作活動は、じつは私が来る前の年から始まっていたらしい。当初は下栗蕎麦――この谷のもう一つの名産だ――その蕎麦だけを育てていた。そして二年目の挑戦として、下栗芋(二度芋)が新たに加わったのだという。',
      '聞けば、よくできた組み合わせだった。芋を掘り上げたあとの畑に、すぐ蕎麦の種をまける。芋の裏作として蕎麦がぴたりと収まるのだ。ひとつの畑が、一年のうちに二度はたらく。先人たちの知恵が、そこに静かに息づいていた。',
    ],
  },
  {
    kicker: '第四話',
    title: '通うようになった理由',
    paragraphs: [
      '年に何度か、慰労会が開かれた。',
      '指導してくださる地域の方々や、先輩ボランティアたちと、とりとめのない話をしながら飲み食いする。畑では聞けない谷の昔話や、誰それの噂話。そういう時間が、作業そのものと同じくらい楽しかった。',
      '',
      '秘境だから、自然環境がいいのは言うまでもない。けれど、それ以上に私を捉えたのは、ここに集まる人たちの面倒見のよさと、ほどよく強引な「押し」だった。「また来いよ」「次はいつ来る」――そう言われて、悪い気のする人間はそういない。気がつけば私は、その温度にすっかり呑まれていた。',
      '',
      'こうして私は、それから毎年この谷へ通うことになる。',
      '毎年、同じ作物の、同じ作業をしているはずなのに、ふしぎと飽きない。むしろ通うほどに、新しい発見がある。天候に一喜一憂し、地域の事情にもだんだん詳しくなる。',
      'やがて、離れていても畑の様子が気になるようになり、仲間うちで小さなセンサー――気温や土の湿りを記録する手づくりの装置――を畑に置いてみたりもした。下栗の里にいなくても、画面の向こうに谷の天気を感じられる。そんな「ゆるいつながり」が、私たちと土地のあいだに、少しずつ育っていった。',
    ],
  },
  {
    kicker: 'エピローグ',
    title: '活動は、続いていく',
    paragraphs: [
      'そして、物語はここから少しずつ枝を広げていく。',
      '私たちの「やってみたい」と、地域の指導者たちの親切――あるいは、ちょっとした思惑?――が重なって、私たちは大豆の畑をはじめ、やがて茶畑にまで手を伸ばすことになる。手摘みのお茶づくりなんて、最初は誰も本気で考えていなかったはずなのに。',
      '',
      '小さな下栗芋から始まったゆるいつながりは、年を追うごとに人を巻き込み、形を変えていった。そして二〇二四年十月、私たちはひとつの区切りを迎える。任意のサークルだった集まりが、一般社団法人「遠山郷応援会」として、あらためて歩みだしたのだ。',
      'それは、谷を守りたいという思いを、その場かぎりのものにしないための選択だった。受け継いできた畑も、出会えた人たちとの縁も、次の世代へきちんと手渡していくために。',
      '',
      'はじまりは、たった一枚の貼り紙だった。',
      '「二度芋を、つくってみませんか」――その一言に、ほんの軽い気持ちで手を挙げた。ただそれだけのことが、こんなにも長く、こんなにも豊かに続いていくなんて、あの冬の私は思いもしなかった。',
      'この物語には、まだ続きがある。次の畝を耕すのは、もしかしたら――あなたかもしれない。',
    ],
  },
]
---

<BaseLayout title="遠山郷との始まり">
  <section
    class="relative overflow-hidden bg-gradient-to-b from-sky-soft via-base to-base px-4 pt-14 pb-10 text-center sm:pt-20"
  >
    <span
      class="mx-auto mb-4 flex w-fit items-center gap-2 rounded-full bg-sunlight-soft px-4 py-1 font-serif text-sm tracking-wide text-primary-deep
             before:content-['▲'] before:text-xs before:text-accent-strong"
    >
      AIライトノベル
    </span>
    <h1
      class="font-serif font-medium text-primary text-3xl leading-snug md:text-4xl"
    >
      遠山郷との始まり
    </h1>
    <p class="mx-auto mt-4 max-w-xl leading-loose text-body">
      一枚の貼り紙から始まった、ある秘境通いの記録。<br
        class="hidden sm:inline"
      />私たちがどうやって遠山郷とつながり、畑を続けてきたのか――その物語をお届けします。
    </p>
    <div class="mx-auto mt-8 w-full max-w-3xl">
      <Image
        src={mountsImage}
        alt="遠山郷の山並みと谷あいの里"
        class="aspect-video w-full rounded-3xl object-cover shadow-lg ring-1 ring-primary/10"
      />
    </div>
  </section>

  <Container class="py-12 md:py-16">
    <StoryReader client:load pages={pages} />
  </Container>
</BaseLayout>
