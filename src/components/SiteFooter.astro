---
/**
 * SiteFooter — 共通フッター。
 *
 * 旧・左下フローティング `RouterMenu`（法令メニュー）の収れん先 (CLAUDE.md 実装ステップ 10)。
 * ジャーナリー導線はヘッダー (`SiteHeader.astro`) が担い、フッターは
 * 「法令・規約」と「主たる事務所の所在地」（信頼性・法令対応の情報）を整理して受け持つ。
 *
 * - 法令・規約: 定款 / 公告 / 特定商取引法に基づく表記
 *   （公告の URL は法人登記に記載のため変更禁止）
 * - 主たる事務所の所在地（法人名はフッタータイトル、詳細な事業者情報は特商法表記ページに集約）
 * - デザイン規則: 二重の山アイコン（ロゴと同系統の重なる稜線）/ green・sunlight 基調 (CLAUDE.md)
 *   リンクマーカーは奥＝ティール・手前＝陽光、現在ページは手前をコーラル(accent)にする。
 * a11y: 現在ページに aria-current="page" を付与する。
 */
import Container from '~/components/Container.astro'
import SiteLogo from '~/components/SiteLogo.astro'

interface Props {
  currentPath?: string
}

const { currentPath = Astro.url.pathname } = Astro.props

// ハッシュ/末尾スラッシュを無視してパスを比較する (SiteHeader と同方針)
const normalize = (p: string) =>
  p.split('?')[0].split('#')[0].replace(/\/$/, '') || '/'
const isActivePath = (path: string) =>
  !path.startsWith('http') && normalize(path) === normalize(currentPath)

// 法令・規約 (旧 RouterMenu の収れん先)
const legalLinks = [
  { path: '/articles', title: '定款' },
  { path: '/public_notices', title: '公告' },
  { path: '/notation', title: '特定商取引法に基づく表記' },
]

const year = new Date().getFullYear()

const linkClass = (active: boolean) =>
  [
    'inline-flex items-center gap-2 py-1 transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sunlight',
    active ? 'text-white' : 'text-white/80 hover:text-white',
  ].join(' ')

// 本文中のインラインリンク (参加・購入・寄付)。点線下線でリンクと分かるようにする
const inlineLinkClass =
  'text-white/90 underline decoration-dotted decoration-1 underline-offset-4 transition-colors hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sunlight'
---

<footer class="shrink-0 border-t-2 border-sunlight bg-primary-deep text-white">
  <Container size="wide" class="py-8 sm:py-10">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-[1.4fr_1fr_1fr]">
      <!-- ブランド -->
      <div>
        <a
          href="/"
          class="inline-flex items-center gap-2 font-serif text-lg font-medium transition-opacity hover:opacity-80 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sunlight"
        >
          <SiteLogo class="h-8 w-8 shrink-0" />
          一般社団法人遠山郷応援会
        </a>
        <p class="mt-3 text-sm leading-relaxed text-white/70">
          長野県・遠山郷の里山と暮らしを、<a
            href="/join"
            class={inlineLinkClass}>参加</a
          >・<a href="/products" class={inlineLinkClass}>購入</a>・<a
            href="/support"
            class={inlineLinkClass}>寄付</a
          >を通じてみんなで応援しています。
        </p>
      </div>

      <!-- 法令・規約 -->
      <nav aria-label="法令・規約">
        <h2 class="mb-3 font-serif text-sm font-medium text-white/90">
          法令・規約
        </h2>
        <ul class="flex flex-col text-sm">
          {
            legalLinks.map((link) => {
              const active = isActivePath(link.path)
              return (
                <li>
                  <a
                    href={link.path}
                    aria-current={active ? 'page' : undefined}
                    class={linkClass(active)}
                  >
                    {/* 二重の山アイコン (奥=ティール / 手前=陽光・現在ページはコーラル) */}
                    <svg
                      class="h-3.5 w-[1.04rem] shrink-0"
                      viewBox="0 0 19 16"
                      aria-hidden="true"
                      xmlns="http://www.w3.org/2000/svg"
                    >
                      <path d="M1 15L7 1.5L13 15Z" fill="#44b08c" />
                      <path
                        d="M9 15L13.5 9.5L18 15Z"
                        fill={active ? '#f06b4b' : '#ffc24b'}
                      />
                    </svg>
                    <span class="underline decoration-dotted decoration-1 underline-offset-4">
                      {link.title}
                    </span>
                  </a>
                </li>
              )
            })
          }
        </ul>
      </nav>

      <!-- 主たる事務所の所在地 -->
      <div class="text-sm text-white/70">
        <h2 class="mb-3 font-serif text-sm font-medium text-white/90">
          主たる事務所の所在地
        </h2>
        <address class="not-italic leading-relaxed">
          〒399-1311<br />
          長野県飯田市南信濃和田1239番地
        </address>
      </div>
    </div>

    <p class="mt-8 border-t border-white/15 pt-6 text-xs text-white/60">
      © {year} 一般社団法人遠山郷応援会
    </p>
  </Container>
</footer>
