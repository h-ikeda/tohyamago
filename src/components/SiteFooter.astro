---
/**
 * SiteFooter — 共通フッター。
 *
 * 旧・左下フローティング `RouterMenu`（法令メニュー）の収れん先 (CLAUDE.md 実装ステップ 10)。
 * ジャーナリー導線はヘッダー (`SiteHeader.astro`) が担い、フッターは
 * 「法令・規約」と「法人概要」（信頼性・法令対応の情報）を整理して受け持つ。
 *
 * - 法令・規約: 定款 / 公告 / 特定商取引法に基づく表記
 *   （公告の URL は法人登記に記載のため変更禁止）
 * - 法人概要: 名称・所在地（詳細は特商法表記ページに集約）
 * - デザイン規則: 三角形(▲) モチーフ / green・sunlight 基調 (CLAUDE.md)
 * a11y: 現在ページに aria-current="page" を付与する。
 */
import Container from '~/components/Container.astro'
import SiteLogo from '~/components/SiteLogo.astro'

interface Props {
  currentPath?: string
}

const { currentPath = Astro.url.pathname } = Astro.props

// ハッシュ/末尾スラッシュを無視してパスを比較する (SiteHeader と同方針)
const normalize = (p: string) =>
  p.split('?')[0].split('#')[0].replace(/\/$/, '') || '/'
const isActivePath = (path: string) =>
  !path.startsWith('http') && normalize(path) === normalize(currentPath)

// 法令・規約 (旧 RouterMenu の収れん先)
const legalLinks = [
  { path: '/articles', title: '定款' },
  { path: '/public_notices', title: '公告' },
  { path: '/notation', title: '特定商取引法に基づく表記' },
]

const year = new Date().getFullYear()

const linkClass = (path: string) =>
  [
    'inline-flex items-center gap-2 py-1 text-white/80 transition-colors hover:text-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sunlight',
    "before:text-[0.6rem] before:text-sunlight before:content-['▲']",
    isActivePath(path) && 'text-white before:text-accent',
  ]
    .filter(Boolean)
    .join(' ')
---

<footer
  class="shrink-0 border-t-4 border-sunlight bg-primary-deep text-white relative
         before:border-x-[0.58rem] before:border-b-[1rem] before:border-x-transparent before:border-b-sunlight before:absolute before:right-3.5 before:-top-[1.3rem]
         after:border-x-[0.58rem] after:border-b-[1rem] after:border-x-transparent after:border-b-accent after:absolute after:right-2 after:-top-[1.4rem] after:scale-110 after:origin-bottom-right"
>
  <Container size="wide" class="py-10">
    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-[1.4fr_1fr_1fr]">
      <!-- ブランド -->
      <div>
        <a
          href="/"
          class="inline-flex items-center gap-2 font-serif text-lg font-medium transition-opacity hover:opacity-80 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sunlight"
        >
          <SiteLogo class="h-8 w-8 shrink-0" />
          遠山郷応援会
        </a>
        <p class="mt-3 text-sm leading-relaxed text-white/70">
          長野県・遠山郷の里山と暮らしを、参加・購入・寄付でみんなで応援する一般社団法人です。
        </p>
      </div>

      <!-- 法令・規約 -->
      <nav aria-label="法令・規約">
        <h2 class="mb-3 font-serif text-sm font-medium text-white/90">
          法令・規約
        </h2>
        <ul class="flex flex-col text-sm">
          {
            legalLinks.map((link) => (
              <li>
                <a
                  href={link.path}
                  aria-current={isActivePath(link.path) ? 'page' : undefined}
                  class={linkClass(link.path)}
                >
                  {link.title}
                </a>
              </li>
            ))
          }
        </ul>
      </nav>

      <!-- 法人概要 -->
      <div class="text-sm not-italic text-white/70">
        <h2 class="mb-3 font-serif text-sm font-medium text-white/90">
          法人概要
        </h2>
        <address class="space-y-1 not-italic leading-relaxed">
          <p>一般社団法人遠山郷応援会</p>
          <p>
            〒399-1311<br />
            長野県飯田市南信濃和田1239番地
          </p>
        </address>
        <a
          href="/notation"
          aria-current={isActivePath('/notation') ? 'page' : undefined}
          class="mt-2 inline-flex items-center gap-1 text-white/80 underline-offset-4 transition-colors hover:text-white hover:underline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sunlight"
        >
          事業者情報の詳細
        </a>
      </div>
    </div>

    <p class="mt-8 border-t border-white/15 pt-6 text-xs text-white/60">
      © {year} 一般社団法人遠山郷応援会
    </p>
  </Container>
</footer>
