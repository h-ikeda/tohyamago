---
/**
 * SiteLogo — ブランドマーク (遠山郷の重なる稜線 + 陽光 + コーラルの頂)。
 *
 * デザイン規則 (CLAUDE.md):
 * - 三角形(▲)=山 を核モチーフに、里山ポップの多色(深緑/ティール/陽光/コーラル)で構成する。
 * - 「遠山」= 遠く重なる三つの稜線で奥行き(遠さ)を表現する。
 * - 手前のコーラルの頂は、既存ロゴの before:▲(accent) を継承するブランドの差し色。
 *   「守る人の想い・手仕事の温かさ」を象徴する。
 * - 陽光イエローの太陽は、農と希望(あたたかさ)を象徴する。
 *
 * 装飾要素のため aria-hidden。団体名は隣接テキストで読み上げられる。
 * favicon (public/favicon.svg) も同じ意匠で展開している。
 */
interface Props {
  class?: string
}

const { class: className } = Astro.props
---

<svg
  class={className}
  viewBox="0 0 40 40"
  role="img"
  aria-hidden="true"
  xmlns="http://www.w3.org/2000/svg"
>
  <!-- 陽光 (希望・農のあたたかさ)。光条のサンバーストで山から昇る陽を表現 -->
  <path
    d="M27 8L28.32 10.07L30.5 8.94L30.61 11.39L33.06 11.5L31.93 13.68L34 15L31.93 16.32L33.06 18.5L30.61 18.61L30.5 21.06L28.32 19.93L27 22L25.68 19.93L23.5 21.06L23.39 18.61L20.94 18.5L22.07 16.32L20 15L22.07 13.68L20.94 11.5L23.39 11.39L23.5 8.94L25.68 10.07Z"
    fill="#ffc24b"></path>
  <!-- 奥の稜線 (遠さ・ティール緑) -->
  <path d="M2 33L13 11L25 33Z" fill="#44b08c"></path>
  <!-- 主峰 (深緑) -->
  <path d="M8 33L20 15L32 33Z" fill="#1f855f"></path>
  <!-- 手前の頂 (コーラル＝守る人の想い・ブランドの差し色) -->
  <path d="M23 33L30 20L38 33Z" fill="#f06b4b"></path>
</svg>
