---
/**
 * PostCard — 近況一覧用のダイジェストカード。
 * 記事本文を全文ではなく抜粋 (数行) で見せ、写真があればサムネイルを 1 枚添える。
 * カード全体が記事個別ページ (/news/[slug]) へのリンクになっており、
 * タップで続きを読める。高さがほぼ揃うよう抜粋は line-clamp で行数を制限する。
 */
import { Image } from 'astro:assets'
import type { CollectionEntry } from 'astro:content'
import Card from '~/components/Card.astro'
import { postExcerpt } from '~/components/postExcerpt'
import { formatPostDate } from '~/components/postDate'

interface Props {
  post: CollectionEntry<'posts'>
  class?: string
}

const { post, class: className = '' } = Astro.props
const excerpt = postExcerpt(post.body)
const thumbnail = post.data.images[0]
---

<Card as="article" hover class:list={['h-full', className]}>
  <a
    href={`/news/${post.id}`}
    class="flex h-full flex-col focus:outline-none focus-visible:ring-2 focus-visible:ring-accent-strong focus-visible:ring-offset-2"
  >
    {
      thumbnail && (
        <Image
          src={thumbnail}
          alt=""
          class="aspect-video w-full border-b border-primary/10 object-cover saturate-[0.85]"
        />
      )
    }
    <div class="flex flex-1 flex-col px-5 pt-4 pb-5">
      <time class="block font-mono text-xs font-medium text-accent-strong">
        {formatPostDate(post.data.date)}
      </time>
      {
        excerpt ? (
          <p class="mt-2 line-clamp-3 leading-relaxed text-body">{excerpt}</p>
        ) : (
          <p class="mt-2 text-sm leading-relaxed text-body/60">
            写真でつづる記録です。
          </p>
        )
      }
      <span
        class="mt-3 inline-flex items-center gap-1 text-sm font-medium text-accent-strong after:content-['→']"
      >
        続きを読む
      </span>
    </div>
  </a>
</Card>
