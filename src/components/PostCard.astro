---
/**
 * PostCard — 近況一覧用のダイジェストカード。
 * 記事本文を全文ではなく抜粋 (数行) で見せ、写真があればサムネイルを 1 枚添える。
 * カード全体が記事個別ページ (/news/[slug]) へのリンクになっており、
 * タップで続きを読める。高さがほぼ揃うよう抜粋は line-clamp で行数を制限する。
 */
import type { CollectionEntry } from 'astro:content'
import BlurImage from '~/components/BlurImage.astro'
import Card from '~/components/Card.astro'
import ArrowIcon from '~/components/ArrowIcon.astro'
import { postExcerpt } from '~/components/postExcerpt'
import { formatPostDate } from '~/components/postDate'

interface Props {
  post: CollectionEntry<'posts'>
  class?: string
}

const { post, class: className = '' } = Astro.props
const excerpt = postExcerpt(post.body)
const thumbnail = post.data.images[0]
---

<Card as="article" hover class:list={['h-full', className]}>
  <a
    href={`/news/${post.id}`}
    class="group flex h-full flex-col focus:outline-none focus-visible:ring-2 focus-visible:ring-accent-strong focus-visible:ring-offset-2"
  >
    {
      thumbnail && (
        <BlurImage
          src={thumbnail}
          alt=""
          sizes="(min-width: 640px) 360px, 100vw"
          class="aspect-video w-full border-b border-primary/10"
          imgClass="h-full! w-full object-cover saturate-[0.85]"
        />
      )
    }
    <div class="flex flex-1 flex-col px-5 pt-4 pb-5">
      <time
        class="block font-mono text-xs font-medium text-accent-strong"
        datetime={post.data.date.toISOString()}
      >
        {formatPostDate(post.data.date)}
      </time>
      <h3
        class="mt-1.5 font-serif text-lg leading-snug font-medium text-primary"
      >
        {post.data.title}
      </h3>
      {
        excerpt ? (
          <p class="mt-1.5 line-clamp-2 text-sm leading-relaxed text-body/80">
            {excerpt}
          </p>
        ) : (
          <p class="mt-1.5 text-sm leading-relaxed text-body/60">
            写真でつづる記録です。
          </p>
        )
      }
      <span
        class="mt-3 inline-flex items-center gap-1.5 text-sm font-medium text-accent-strong"
      >
        続きを読む
        <ArrowIcon
          class="h-[1.1em] w-[1.1em] transition-transform motion-safe:group-hover:translate-x-0.5"
        />
      </span>
    </div>
  </a>
</Card>
