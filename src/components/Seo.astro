---
// 検索エンジン / SNS / AI 検索向けの <head> メタ情報をまとめて出力する。
// 値の解決 (description の既定・OG 画像生成・JSON-LD 組み立て) は BaseLayout 側で
// 行い、本コンポーネントはタグの描画に専念する (issue #215)。
import {
  SITE_NAME,
  SITE_LOCALE,
  THEME_COLOR,
  OG_IMAGE_WIDTH,
  OG_IMAGE_HEIGHT,
  serializeJsonLd,
} from '~/components/siteMeta'

interface Props {
  /** 接尾辞込みの完全な <title>。og:title / twitter:title にも使う。 */
  title: string
  description: string
  canonicalURL: string
  /** og:type (website / article)。 */
  ogType: string
  /** OG 画像の絶対 URL (1200x630)。 */
  imageURL: string
  imageAlt: string
  /** robots に noindex を出すか (404 など)。 */
  noindex?: boolean
  /** 記事の公開日時 (ISO 文字列)。article のときのみ出力。 */
  publishedTime?: string
  /** 記事タグ (article:tag)。 */
  tags?: string[]
  /** ページ固有を含む JSON-LD オブジェクト群。 */
  structuredData?: Record<string, unknown>[]
}

const {
  title,
  description,
  canonicalURL,
  ogType,
  imageURL,
  imageAlt,
  noindex = false,
  publishedTime,
  tags = [],
  structuredData = [],
} = Astro.props
---

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
<meta name="author" content={SITE_NAME} />
{
  noindex ? (
    <meta name="robots" content="noindex, nofollow" />
  ) : (
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />
  )
}
<meta name="theme-color" content={THEME_COLOR} />

{/* Open Graph (Facebook / 各種フォーラム / AI クローラー) */}
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content={SITE_NAME} />
<meta property="og:locale" content={SITE_LOCALE} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={imageURL} />
<meta property="og:image:secure_url" content={imageURL} />
<meta property="og:image:type" content="image/jpeg" />
<meta property="og:image:width" content={String(OG_IMAGE_WIDTH)} />
<meta property="og:image:height" content={String(OG_IMAGE_HEIGHT)} />
<meta property="og:image:alt" content={imageAlt} />
{
  ogType === 'article' && publishedTime && (
    <meta property="article:published_time" content={publishedTime} />
  )
}
{
  ogType === 'article' &&
    tags.map((tag) => <meta property="article:tag" content={tag} />)
}

{/* Twitter (X) Card */}
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL} />
<meta name="twitter:image:alt" content={imageAlt} />

{/* 構造化データ (JSON-LD): 検索リッチリザルト・AI 検索の引用に寄与 */}
{
  structuredData.map((data) => (
    <script
      is:inline
      type="application/ld+json"
      set:html={serializeJsonLd(data)}
    />
  ))
}
