---
/**
 * SectionHeading — 三角形 (▲) モチーフ付きの見出し。
 * 旧 green/lime の border-trick を新パレット (primary + accent) へ再定義。
 * primary(深い森) と accent(土・テラコッタ) の二色三角を重ね、ブランド表現とする。
 */
interface Props {
  as?: 'h1' | 'h2' | 'h3'
  level?: 'page' | 'section' | 'sub'
  align?: 'center' | 'left'
  class?: string
}

const { as = 'h2', level = 'section', align = 'center', class: className = '' } = Astro.props
const Tag = as

// 見出しレベルごとの文字サイズと三角サイズ
const sizes = {
  page: { text: 'text-2xl md:text-3xl', tri: 'text-2xl md:text-3xl' },
  section: { text: 'text-xl md:text-2xl', tri: 'text-xl md:text-2xl' },
  sub: { text: 'text-lg', tri: 'text-lg' },
}
const size = sizes[level]
const alignment = align === 'center' ? 'mx-auto w-fit' : 'w-fit'
---

<Tag
  class:list={[
    'flex items-center gap-3 font-serif font-medium text-primary',
    size.text,
    alignment,
    className,
  ]}
>
  <span
    class:list={[
      'inline-block relative shrink-0',
      // accent (背面) の三角
      "before:content-[''] before:absolute before:left-0 before:bottom-0 before:border-x-transparent before:border-x-[0.5em] before:border-b-[0.85em] before:border-b-accent before:translate-x-0.5 before:translate-y-0.5",
      // primary (前面) の三角
      "after:content-[''] after:block after:border-x-transparent after:border-x-[0.5em] after:border-b-[0.85em] after:border-b-primary",
    ]}
    aria-hidden="true"
  >
  </span>
  <slot />
</Tag>
